{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "admin.html", "use": "@vercel/static" },
    { "src": "admin-dashboard.html", "use": "@vercel/static" },
    { "src": "api-client.js", "use": "@vercel/static" },
    { "src": "hero.png", "use": "@vercel/static" },
    { "src": "images/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/admin-dashboard.html", "dest": "/admin-dashboard.html" },
    { "src": "/admin.html", "dest": "/admin.html" },
    { "src": "/api-client.js", "dest": "/api-client.js" },
    { "src": "/hero.png", "dest": "/hero.png" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
