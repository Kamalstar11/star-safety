# Star Safety – Server Environment Variables
# ─────────────────────────────────────────────────────────
# STEP 1: MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com
# Go to: Your Cluster → Connect → Connect your application → Copy the string
# Replace <password> with your actual DB password
# Replace <dbname> with: starsafety

MONGODB_URI=mongodb+srv://starsafety:StarDB%402024@cluster0.btnovgo.mongodb.net/starsafety?retryWrites=true&w=majority&appName=Cluster0

# ─────────────────────────────────────────────────────────
# STEP 2: JWT Secret (keep this secret, any random string)
JWT_SECRET=StarSafety_SuperSecret_JWT_2024!

# ─────────────────────────────────────────────────────────
# Admin Credentials (matches your existing login)
ADMIN_ID=STAR0010
ADMIN_PASSWORD=Star@@@0909

# ─────────────────────────────────────────────────────────
# Server Port
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8000
